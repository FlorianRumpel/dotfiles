{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 400,
  "control-center-margin-right": 5,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,

  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 350,
  "control-center-height": 500,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "script-fail-notify": true,

  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Normal",
      "app-name": "example.app.id"
    }
  },

  "widgets": ["inhibitors", "title", "dnd", "notifications", "buttons-grid"],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },

    "label": {
      "max-lines": 5,
      "text": "Label Text"
    },
    "mpris": {
      "blacklist": [],
      "autohide": true,
      "show-album-art": "always",
      "loop-carousel": false
    },

    "buttons-grid": {
      "buttons-per-row": 7,
      "actions": [
        {
          "label": "󰖩",
          "type": "normal",
          "active": true,
          "command": "iwgtk & swaync-client -t ",
          "update-command": ""
        },
        {
          "label": "󰂯",
          "type": "normal",
          "active": true,
          "command": "blueman-manager & swaync-client -t ",
          "update-command": ""
        },
        {
          "label": "",
          "type": "normal",
          "active": true,
          "command": "code /home/florian/.dotfiles & swaync-client -t",
          "update-command": ""
        },
        {
          "label": "",
          "type": "normal",
          "active": true,
          "command": "PATH=$HOME/scripts:$PATH && change-wallpaper",
          "update-command": ""
        },
        {
          "label": "",
          "type": "normal",
          "active": true,
          "command": "gnome-text-editor ~/Pictures/wallpapers/active-wallpapers.txt",
          "update-command": ""
        },
        {
          "label": "󰖔",
          "type": "normal",
          "active": true,
          "command": "pkill hyprsunset || hyprsunset",
          "update-command": ""
        },
        {
          "label": "Switch Theme",
          "type": "normal",
          "active": true,
          "command": "/home/florian/scripts/apply-theme && swaync-client -t",
          "update-command": ""
        }
      ]
    }
  }
}
