{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": { "color": { "1": "blue", "2": "blue" } },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "de",
    "terminal",
    "terminalfont",
    "cpu",
    "gpu",
    {
      "type": "memory",
      "percent": {
        "type": 1,
      },
    },
    "_swap",
    "localip",
    "battery",
    "poweradapter",
    "_wm",
    "_disk",
    "_wmtheme",
    "_theme",
    "_icons",
    "_font",
    "_cursor",
    "_locale",
    "_break",
    "_colors",
  ],
}
